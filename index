let gc=0,gsc=0,gwn=0,gtm=null,gtl=20,gans=false;
const CIRC=194.8;

function startG(){
  document.getElementById('gss').style.display='none';
  document.getElementById('gps').style.display='block';
  document.getElementById('grs').classList.remove('show');
  gc=0;gsc=0;gwn=0;updSt();showQ();
}
function updSt(){
  document.getElementById('gqn').textContent=gc+1;
  document.getElementById('gsc').textContent=gsc;
  document.getElementById('gwn').textContent=gwn;
  document.getElementById('pfill').style.width=((gc/QS.length)*100)+'%';
}
function showQ(){
  if(gc>=QS.length){endG();return;}
  const q=QS[gc];gans=false;
  document.getElementById('gqb').textContent='No. '+(gc+1);
  document.getElementById('gqcat').textContent=q.cat;
  document.getElementById('gqt').textContent=q.q;
  const og=document.getElementById('gopt');og.innerHTML='';
  q.o.forEach((opt,i)=>{const b=document.createElement('button');b.className='ob2';b.textContent=opt;b.onclick=()=>selA(i);og.appendChild(b);});
  startTmr();updSt();
}
function startTmr(){
  clearInterval(gtm);gtl=20;
  const ring=document.getElementById('tring');
  document.getElementById('tnum').textContent=gtl;
  ring.style.stroke='#ffd700';ring.style.strokeDashoffset='0';
  gtm=setInterval(()=>{
    gtl--;document.getElementById('tnum').textContent=gtl;
    ring.style.strokeDashoffset=CIRC*(1-gtl/20);
    if(gtl<=5)ring.style.stroke='#e74c3c';
    else if(gtl<=10)ring.style.stroke='#f39c12';
    if(gtl<=0){clearInterval(gtm);if(!gans)timeUp();}
  },1000);
}
function timeUp(){
  gans=true;gwn++;
  const q=QS[gc];
  const btns=document.querySelectorAll('.ob2');btns.forEach(b=>b.disabled=true);btns[q.a].classList.add('correct');
  showFB('⏰','Waktu Habis!','Jawaban: '+q.o[q.a],false);setTimeout(nextQ,1800);
}
function selA(idx){
  if(gans)return;clearInterval(gtm);gans=true;
  const q=QS[gc];const btns=document.querySelectorAll('.ob2');btns.forEach(b=>b.disabled=true);
  if(idx===q.a){gsc++;btns[idx].classList.add('correct');showFB('🎉','BENAR!','Mantap sekali! 🌟',true);}
  else{gwn++;btns[idx].classList.add('wrong');btns[q.a].classList.add('correct');showFB('😅','Kurang Tepat','Yuk belajar lagi! 💪',false);}
  updSt();setTimeout(nextQ,1700);
}
function showFB(e,t,s,ok){
  const ov=document.getElementById('fov');
  document.getElementById('foe').textContent=e;document.getElementById('fot').textContent=t;document.getElementById('fos').textContent=s;
  ov.style.background=ok?'rgba(39,174,96,.92)':'rgba(231,76,60,.92)';
  ov.classList.add('show');setTimeout(()=>ov.classList.remove('show'),1200);
}
function nextQ(){gc++;showQ();}
function endG(){
  clearInterval(gtm);
  document.getElementById('gps').style.display='none';
  const rs=document.getElementById('grs');rs.classList.add('show');
  const pct=Math.round((gsc/QS.length)*100);
  document.getElementById('rsco').textContent=gsc+'/30';
  document.getElementById('rc').textContent=gsc;document.getElementById('rw').textContent=gwn;document.getElementById('rn').textContent=pct;
  let s='⭐',t='Semangat Terus!',m='Baca lagi materinya, kamu pasti bisa! 💪';
  if(pct>=90){s='🌟🌟🌟';t='SEMPURNA!';m='Luar biasa! Kamu menguasai materi ini! 🏆';confetti();}
  else if(pct>=75){s='⭐⭐⭐';t='HEBAT!';m='Bagus sekali! Sedikit lagi sempurna! 😊';confetti();}
  else if(pct>=60){s='⭐⭐';t='BAGUS!';m='Sudah cukup bagus! Terus berlatih ya! 💪';}
  document.getElementById('rstr').textContent=s;document.getElementById('rttl').textContent=t;document.getElementById('rmsg').textContent=m;
  document.getElementById('rfwk').textContent=pct>=75?'🎊🏆🎊':'📚💪📚';
}
function restartG(){document.getElementById('grs').classList.remove('show');document.getElementById('gss').style.display='block';}

// ======= CONFETTI =======
function confetti(){
  const cls=['#ffd700','#27ae60','#2980b9','#e91e8c','#e67e22','#8e44ad'];
  const c=document.getElementById('ccon');c.innerHTML='';
  for(let i=0;i<55;i++){
    const p=document.createElement('div');p.className='cp';
    p.style.cssText=`left:${Math.random()*100}%;background:${cls[Math.floor(Math.random()*cls.length)]};animation-delay:${Math.random()}s;animation-duration:${2+Math.random()*1.5}s;width:${6+Math.random()*8}px;height:${6+Math.random()*8}px;border-radius:${Math.random()>.5?'50%':'2px'};`;
    c.appendChild(p);
  }
  setTimeout(()=>c.innerHTML='',4000);
}
