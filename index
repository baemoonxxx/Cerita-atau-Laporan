let rvc=0,rvs=0,rvDone=false;

function initRv(){
  rvDone=true;rvc=0;rvs=0;
  document.getElementById('rsc').style.display='none';
  document.getElementById('rcon').style.display='block';
  buildDots();showRvQ();
}
function buildDots(){
  const c=document.getElementById('rdots');c.innerHTML='';
  rvQ.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='rd'+(i===0?' cur':'');d.textContent=i+1;d.id='rd'+i;c.appendChild(d);
  });
}
function showRvQ(){
  const q=rvQ[rvc];
  document.getElementById('rqn').textContent=`Soal ${rvc+1} dari ${rvQ.length}`;
  document.getElementById('rqt').textContent=q.q;
  document.getElementById('rfb').style.display='none';
  ['rfk','rop'].forEach(id=>{const b=document.getElementById(id);b.disabled=false;b.classList.remove('ca','wa');});
}
function ansRv(c){
  const q=rvQ[rvc];const ok=c===q.ans;
  const dot=document.getElementById('rd'+rvc);
  document.getElementById('rfk').disabled=true;document.getElementById('rop').disabled=true;
  if(ok){rvs++;dot.className='rd correct';document.getElementById(c==='fakta'?'rfk':'rop').classList.add('ca');const fb=document.getElementById('rfb');fb.className='rfb correct';fb.innerHTML='✅ Benar! '+q.e;fb.style.display='block';}
  else{dot.className='rd wrong';document.getElementById(c==='fakta'?'rfk':'rop').classList.add('wa');document.getElementById(q.ans==='fakta'?'rfk':'rop').classList.add('ca');const fb=document.getElementById('rfb');fb.className='rfb wrong';fb.innerHTML='❌ Kurang tepat! '+q.e;fb.style.display='block';}
  setTimeout(()=>{
    rvc++;
    if(rvc<rvQ.length){document.getElementById('rd'+rvc).classList.add('cur');showRvQ();}
    else showRvEnd();
  },1600);
}
function showRvEnd(){
  document.getElementById('rcon').style.display='none';
  document.getElementById('rsc').style.display='block';
  document.getElementById('rsb').textContent=rvs+'/10';
  const m=['Terus berlatih ya! 💪','Lumayan! Baca lagi materinya!','Bagus! Hampir sempurna! 😊','LUAR BIASA! Kamu hebat! 🌟'];
  document.getElementById('rsm').textContent=m[Math.min(Math.floor(rvs/3),3)];
  if(rvs>=8)confetti();
}

